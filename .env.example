# 应用环境
APP_ENV=dev

# CORS 允许来源（JSON 数组、逗号分隔或单值）
ALLOWED_ORIGINS=["http://localhost:5173"]

# OAuth 启用列表（JSON 数组、逗号分隔或单值），例如 ["GITHUB","GOOGLE"]
OAUTH_LIST=[]

# 使用本地 mock service 的外部 provider 列表（JSON 数组、逗号分隔或单值）
# 可选值：github_oauth, google_oauth, turnstile, mail, example_external_api
EXTERNAL_PROVIDER_MOCK_LIST=[]
MOCK_PROVIDER_BACKEND_URL=http://localhost:8000
MOCK_PROVIDER_PUBLISH_INTERVAL_SECONDS=2

# 应用密钥（示例值，请在生产中覆盖）
APP_SECRET_KEY=change-me

# 数据库文件路径（相对项目根）
DATABASE_PATH=data/database.db

# 端口（仅 run.py 使用）
PORT=8000

# 日志级别：debug/info/warning/error
LOG_LEVEL=info
LOG_DIR=logs
LOG_ROTATION=20 MB
LOG_RETENTION=14 days
LOG_SERIALIZE=false

# 前端 Vite 配置
VITE_API_BASE_URL=/api
# 生产或直连 Cloudflare 时配置；dev mock 模式会从后端 runtime config 读取
VITE_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile（前后端联动防机器人）
TURNSTILE_ENABLED=false
TURNSTILE_SECRET_KEY=
TURNSTILE_VERIFY_TIMEOUT_SECONDS=4

# 初始化管理员
INIT_ADMIN_NAME=admin
INIT_ADMIN_PASSWORD=admin123
INIT_ADMIN_EMAIL=admin@example.com

# 邮件发送配置
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=465
MAIL_USE_SSL=true
MAIL_USE_TLS=false
MAIL_TIMEOUT=5
MAIL_SENDER_EMAIL=
MAIL_SENDER_PASSWORD=
MAIL_SENDER_NAME=
APP_DOMAIN=

# GitHub OAuth 配置
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/oauth/github/callback
GITHUB_SCOPE=read:user user:email

# Google OAuth 配置
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/google/callback
GOOGLE_SCOPE=openid email profile

# 示例外部 API Provider 配置（real provider 会请求 {base_url}/status）
EXAMPLE_EXTERNAL_API_BASE_URL=

# 互动电影视频上传：腾讯云 COS / S3-compatible API
# 示例 endpoint：https://cos.ap-guangzhou.myqcloud.com
INTERACTIVE_MOVIE_S3_ENDPOINT_URL=
INTERACTIVE_MOVIE_S3_REGION_NAME=
INTERACTIVE_MOVIE_S3_BUCKET=
INTERACTIVE_MOVIE_S3_ACCESS_KEY_ID=
INTERACTIVE_MOVIE_S3_SECRET_ACCESS_KEY=
INTERACTIVE_MOVIE_S3_PREFIX=interactive-movie
# 如果 Bucket/CDN 可公网访问，建议配置；否则后端会返回临时预签名 URL
INTERACTIVE_MOVIE_S3_PUBLIC_BASE_URL=
INTERACTIVE_MOVIE_S3_PRESIGN_EXPIRES_SECONDS=3600
INTERACTIVE_MOVIE_MAX_VIDEO_UPLOAD_MB=200

# ChatUI 对话模型：兼容 OpenAI / DeepSeek / 其它 OpenAI-compatible 网关
CHAT_API_BASE_URL=https://api.openai.com/v1
CHAT_API_KEY=
CHAT_MODEL=gpt-5.5
CHAT_SYSTEM_PROMPT=你是中影广告的互动影游创作助手，擅长给用户提供帮助。
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=100000
CHAT_TIMEOUT_SECONDS=45

# AI Wiki / OpenCode 演示配置
# OpenCode 命令；如果 opencode 不在 PATH，可改成绝对路径，例如 /home/you/.local/share/pnpm/opencode
AIWIKI_OPENCODE_COMMAND=opencode
# OpenCode 配置文件；云端部署前执行：cp config/config.json.example config/config.json
AIWIKI_OPENCODE_CONFIG_PATH=config/config.json
# config/config.json.example 默认使用 OpenAI provider，会读取这个环境变量
OPENCODE_OPENAI_API_KEY=
# 如需切回 DeepSeek，可把 config/config.json 中 model 改为 deepseek/deepseek-v4-pro
DEEPSEEK_API_KEY=
# 可选：指定模型，例如 openai/gpt-5.1-codex 或 deepseek/deepseek-v4-pro；留空则使用 OpenCode 配置文件
# 如果 config/config.json 已经写了 model，建议这里留空；这里非空时会作为 CLI --model 覆盖配置文件
AIWIKI_OPENCODE_MODEL=
# 可选：指定 OpenCode agent；留空则使用默认 agent
AIWIKI_OPENCODE_AGENT=
# 可选：传给 opencode run 的额外参数，例如 --dangerously-skip-permissions
AIWIKI_OPENCODE_EXTRA_ARGS=
# 同时运行的 AI Wiki 生成任务数；超过后排队
AIWIKI_MAX_CONCURRENT=5
# 单个任务超时时间（秒）
AIWIKI_TASK_TIMEOUT_SECONDS=1800
# 单个任务上传总大小上限（MB）
AIWIKI_MAX_UPLOAD_MB=25

# 2FA 配置
TWO_FACTOR_CHALLENGE_TTL_MINUTES=5
TWO_FACTOR_SETUP_TTL_MINUTES=10
TWO_FACTOR_ISSUER_NAME=新媒体前沿在线试用
TWO_FACTOR_ENCRYPTION_KEY=fullstack-template-2fa-dev-key-change-me
TWO_FACTOR_BACKUP_CODE_COUNT=8
TWO_FACTOR_MAX_VERIFY_ATTEMPTS=5
