{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}"
      }
    },
    "killm": {
      "name": "KiLLM",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5",
          "limit": {
            "context": 128000,
            "output": 16400
          },
          "variants": {
            "low": {
              "reasoningEffort": "low"
            },
            "medium": {
              "reasoningEffort": "medium"
            },
            "high": {
              "reasoningEffort": "high"
            },
            "extra_hight": {
              "reasoningEffort": "xhigh"
            }
          }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "kimi-k2.5": {
          "name": "Kimi K2.5",
          "limit": {
            "context": 100000,
            "output": 64000
          }
        },
        "kimi-k2.6": {
          "name": "Kimi K2.6",
          "limit": {
            "context": 100000,
            "output": 64000
          }
        }
      },
      "options": {
        "baseURL": "https://ki-llmapi.kispace.cc/v1",
        "apiKey": "{env:KILLM_API_KEY}"
      }
    },
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      }
    }
  },
  "autoupdate": false
}
