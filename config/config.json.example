{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5",
  "small_model": "openai/gpt-5.4-mini",
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://api.openai.com/v1",
        "apiKey": "{env:OPENCODE_OPENAI_API_KEY}"
      }
    },
    "deepseek": {
      "options": {
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      }
    }
  },
  "autoupdate": false
}
